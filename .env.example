# ── Telegram ──────────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── OpenRouter AI ──────────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# AI model to use. Recommended: google/gemini-flash-1.5 (fast + free tier)
# Other options: openai/gpt-4o-mini, anthropic/claude-haiku, mistralai/mistral-7b-instruct
AI_MODEL=google/gemini-flash-1.5

# ── Google Sheets ──────────────────────────────────────────────────────────────
# Path to your Google Service Account credentials JSON file
# See README.md → Step 3 for how to create this
GOOGLE_CREDENTIALS_FILE=credentials.json

# Name of the Google Spreadsheet to use (will be created automatically if missing)
SPREADSHEET_NAME=MyFinance

# ── Bot Settings ───────────────────────────────────────────────────────────────
# Currency symbol shown in all messages (EUR, USD, RUB, UZS, etc.)
CURRENCY=EUR

# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow everyone. Find your ID via @userinfobot
# Example: ALLOWED_USERS=123456789,987654321
ALLOWED_USERS=
